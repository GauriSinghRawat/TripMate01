<% layout('layouts/boilerplate') -%>

<h3>All Listings</h3>

<div class="row row-cols-sm-3 g-3">

  <% for(let listing of allListings) { %>

    <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
      
      <div class="col listing-card">
        <div class="card h-100">

          <img 
            src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" 
            class="card-img-top" 
            style="height:17rem; object-fit: cover;"
            alt="listing_image"
          />

          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br/>
              &#8377 <%= listing.price.toLocaleString("en-IN") %> / night
            </p>
          </div>

        </div>
      </div>

    </a>

  <% } %>

</div>